# EMSI iOS limited production canary access bundle template.
# Copy to `.env.canary` and fill only with approved production or
# staging-production-equivalent values. `.env.canary` is ignored by git.
# Do not use local/dev/test targets, fixture users, or local warehouse DSNs.

EMSI_DP_CANARY_APPROVAL_ID=EMSI-DP-P1A-IOS-CANARY-20260620-AR01
EMSI_DP_CANARY_TARGET_NAME=
EMSI_DP_CANARY_TARGET_CLASS=
EMSI_DP_CANARY_SEEDED_USER_REF=
EMSI_DP_CANARY_SUBJECT_USER_HASH=
EMSI_DP_CANARY_EVENT_ID_PREFIX=
EMSI_DP_CANARY_WINDOW_START=
EMSI_DP_CANARY_WINDOW_END=
EMSI_DP_CANARY_WAREHOUSE_DSN=
EMSI_DP_CANARY_SHARE_ANALYTICS=
EMSI_DP_CANARY_PERSONALIZATION_ENABLED=
EMSI_DP_CANARY_PRIVACY_ARTIFACT=

# Required only for post-run capture after the real iOS canary and downstream
# checks complete. Leave blank for preflight.
EMSI_DP_CANARY_DBT_STATUS=
EMSI_DP_CANARY_DBT_ARTIFACT=
EMSI_DP_CANARY_SODA_STATUS=
EMSI_DP_CANARY_SODA_ARTIFACT=
EMSI_DP_CANARY_DAGSTER_STATUS=
EMSI_DP_CANARY_DAGSTER_ARTIFACT=
EMSI_DP_CANARY_STOP_ROLLBACK_OUTCOME=
