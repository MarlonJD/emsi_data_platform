# EMSI data-platform local-dev version registry.
# Status vocabulary: baseline, local-dev, candidate, rollback-history, blocked.

PLATFORM_STATUS=local-dev

# PostgreSQL
POSTGRES_VERSION=18.4
POSTGRES_IMAGE=postgres:18.4-alpine3.24
POSTGRES_IMAGE_DIGEST=
POSTGRES_IMAGE_STATUS=baseline
POSTGRES_DIGEST_STATUS=blocked-until-repo-local-provenance-captured
POSTGRES_VOLUME_TARGET=/var/lib/postgresql
POSTGRES_PGDATA=/var/lib/postgresql/18/docker
POSTGRES_ROLLBACK_HISTORY_IMAGE=postgres:17-alpine
POSTGRES_ROLLBACK_HISTORY_STATUS=rollback-history

# Python
PYTHON_VERSION=3.12.13
PYTHON_IMAGE=python:3.12.13-slim-bookworm
