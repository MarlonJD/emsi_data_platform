# EMSI data-platform local-dev version registry.
# Status vocabulary: baseline, local-dev, candidate, rollback-history, blocked.

PLATFORM_STATUS=local-dev

# PostgreSQL
POSTGRES_VERSION=18.4
POSTGRES_IMAGE=postgres:18.4-alpine3.24
POSTGRES_IMAGE_DIGEST=
POSTGRES_IMAGE_STATUS=baseline
POSTGRES_DIGEST_STATUS=blocked-until-repo-local-provenance-captured
POSTGRES_VOLUME_TARGET=/var/lib/postgresql
POSTGRES_PGDATA=/var/lib/postgresql/18/docker
POSTGRES_ROLLBACK_HISTORY_IMAGE=postgres:17-alpine
POSTGRES_ROLLBACK_HISTORY_STATUS=rollback-history

# Python
PYTHON_VERSION=3.12.13
PYTHON_IMAGE=python:3.12.13-slim-bookworm
PYTHON_REQUIRES=">=3.12,<3.13"
PYTHON_STATUS=baseline

# Dagster
DAGSTER_VERSION=1.13.9
DAGSTER_WEBSERVER_VERSION=1.13.9
DAGSTER_POSTGRES_VERSION=0.29.9
DAGSTER_DBT_VERSION=0.29.9
DAGSTER_STATUS=local-dev

# dbt
DBT_CORE_VERSION=1.11.11
DBT_POSTGRES_VERSION=1.10.1
DBT_STATUS=baseline
DBT_FUSION_STATUS=candidate-watch

# Data Vault
DATA_VAULT_METHOD=DataVault2.0
DATA_VAULT_PACKAGE=ScalefreeCOM/datavault4dbt
DATA_VAULT_PACKAGE_VERSION=1.18.3
DATA_VAULT_PACKAGE_STATUS=baseline
AUTOMATE_DV_PACKAGE=Datavault-UK/automate_dv
AUTOMATE_DV_VERSION=0.11.4
AUTOMATE_DV_STATUS=candidate-watch

# Soda v4
SODA_CORE_VERSION=4.14.0
SODA_POSTGRES_VERSION=4.14.0
SODA_STATUS=local-dev
SODA_CLOUD_STATUS=blocked-not-used
SODA_LEGACY_V3_POSTGRES_PACKAGE=soda-core-postgres==3.5.6
SODA_LEGACY_V3_STATUS=rollback-history-only

# Superset
SUPERSET_VERSION=6.1.0
SUPERSET_IMAGE=apache/superset:6.1.0
SUPERSET_POSTGRES_DRIVER=psycopg2-binary==2.9.10
SUPERSET_CUSTOM_IMAGE=emsi-superset-postgres-metadata:6.1.0-psycopg2-2.9.10-local
SUPERSET_STATUS=local-dev-candidate
SUPERSET_PRODUCTION_STATUS=blocked-pending-scan-review-provenance-restore

# Grafana
GRAFANA_VERSION=13.0.2
GRAFANA_IMAGE=grafana/grafana:13.0.2
GRAFANA_STATUS=local-dev

# Evidence.dev
NODE_VERSION=22.17.0
NODE_IMAGE=node:22.17.0-bookworm-slim
EVIDENCE_VERSION=40.1.8
EVIDENCE_COMPONENT_UTILITIES_VERSION=4.0.13
EVIDENCE_CORE_COMPONENTS_VERSION=5.4.2
EVIDENCE_SDK_VERSION=4.0.2
EVIDENCE_TAILWIND_VERSION=3.1.4
TYPESCRIPT_VERSION=5.4.2
EVIDENCE_STATUS=local-dev-candidate
EVIDENCE_PRODUCTION_STATUS=blocked-pending-npm-audit-security-owner-acceptance

# Object storage
SEAWEEDFS_VERSION=4.34
SEAWEEDFS_IMAGE=chrislusf/seaweedfs:4.34
SEAWEEDFS_STATUS=local-ci
PRODUCTION_OBJECT_STORAGE_STATUS=candidate-pending-capability-tests

# DuckDB remains helper-only.
DUCKDB_STATUS=local-ci-offline-helper
