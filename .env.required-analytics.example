# EMSI Required Analytics external evidence access bundle template.
# Copy to `.env.required-analytics` and fill only with approved production or
# staging-production-equivalent values. `.env.required-analytics` is ignored by git.
# Do not use local/dev/test targets, fixture users, raw personal data, or local
# warehouse DSNs.

EMSI_REQUIRED_ANALYTICS_TARGET_NAME=
EMSI_REQUIRED_ANALYTICS_TARGET_CLASS=staging-production-equivalent
EMSI_REQUIRED_ANALYTICS_LANES=admin,reveal,note,feedml,clickhouse
EMSI_REQUIRED_ANALYTICS_APPROVAL_IDS=
EMSI_REQUIRED_ANALYTICS_SEEDED_USER_REF=
EMSI_REQUIRED_ANALYTICS_SUBJECT_USER_HASH=
EMSI_REQUIRED_ANALYTICS_EVENT_ID_PREFIX=
EMSI_REQUIRED_ANALYTICS_WINDOW_START=
EMSI_REQUIRED_ANALYTICS_WINDOW_END=
EMSI_REQUIRED_ANALYTICS_WAREHOUSE_DSN=
EMSI_REQUIRED_ANALYTICS_PRIVACY_ARTIFACT=

# Internal QA only. Keep blank for production/staging-equivalent evidence.
# When true, TARGET_CLASS must be internal-qa and the helper may use a local QA
# warehouse DSN. This does not close production/staging evidence gates.
EMSI_REQUIRED_ANALYTICS_ALLOW_INTERNAL_QA_LOCAL_WAREHOUSE=

# Optional SSH tunnel mode for an approved remote warehouse. This keeps the DSN
# hostname as the real warehouse hostname while hostaddr points at the local SSH
# tunnel. Keep blank unless a real approved remote warehouse tunnel is used.
EMSI_REQUIRED_ANALYTICS_WAREHOUSE_TUNNEL_MODE=
EMSI_REQUIRED_ANALYTICS_WAREHOUSE_TUNNEL_SSH_HOST=
EMSI_REQUIRED_ANALYTICS_WAREHOUSE_TUNNEL_REMOTE_HOST=
EMSI_REQUIRED_ANALYTICS_WAREHOUSE_TUNNEL_LOCAL_PORT=
EMSI_REQUIRED_ANALYTICS_WAREHOUSE_TUNNEL_REMOTE_PORT=

# Required only for capture after the Admin scenario and downstream checks
# complete. Leave blank for preflight.
EMSI_REQUIRED_ANALYTICS_ADMIN_SCENARIO_STATUS=
EMSI_REQUIRED_ANALYTICS_ADMIN_SCENARIO_ARTIFACT=
EMSI_REQUIRED_ANALYTICS_DBT_STATUS=
EMSI_REQUIRED_ANALYTICS_DBT_ARTIFACT=
EMSI_REQUIRED_ANALYTICS_SODA_STATUS=
EMSI_REQUIRED_ANALYTICS_SODA_ARTIFACT=
EMSI_REQUIRED_ANALYTICS_DAGSTER_STATUS=
EMSI_REQUIRED_ANALYTICS_DAGSTER_ARTIFACT=
EMSI_REQUIRED_ANALYTICS_FEEDML_COLLECTION_STATUS=
EMSI_REQUIRED_ANALYTICS_FEEDML_COLLECTION_ARTIFACT=
EMSI_REQUIRED_ANALYTICS_CLICKHOUSE_PARITY_STATUS=
EMSI_REQUIRED_ANALYTICS_CLICKHOUSE_PARITY_ARTIFACT=
EMSI_REQUIRED_ANALYTICS_STOP_ROLLBACK_OUTCOME=
